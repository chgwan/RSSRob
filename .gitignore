# AI / agent artifacts (kept out of the repo, per project preference)
CLAUDE.md
AGENT.md
docs/superpowers/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Test / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# RSSRob runtime state — everything generated/mutable lives under var/ and is
# never committed: var/feeds/ (generated XML), var/rssrob.db (item history +
# dedup), var/subscribers.json (emails), var/digest_state.json (sent-state),
# var/wechat_credential.json (personal 公众号 secret).
var/
# stray SQLite DBs anywhere, in case a path isn't pinned under var/
*.db
# generated by tools/select_preview.py (root only — not web/templates/preview.html)
/preview.html

# Local secrets / dotenv files (never commit). .env.example is the committed
# template (not matched by these patterns).
.env
*.env

# OS / editor cruft
.DS_Store
*.swp
.vscode/
.idea/
